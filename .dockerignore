# Virtual environment — never copy this into Docker
.venv/
venv/
env/

# Secret files — injected via environment variables instead
.env

# ChromaDB data — mounted as a volume instead
chroma_db/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Test files
tests/
.pytest_cache/
.coverage

# Editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Git
.git/
.gitignore

# Docs
*.md
LICENSE

# Uploaded temp files
uploads/

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose*.yml
.dockerignore